# =============================================================================
# Evo AI Community — Unified Environment Configuration
# =============================================================================
# Copy this file to .env to get started:
#   cp .env.example .env
#
# The default values below work out of the box for local development.
# No edits required for a basic setup.
# =============================================================================

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================

# PostgreSQL hostname (Docker service name)
POSTGRES_HOST=postgres
# PostgreSQL port
POSTGRES_PORT=5432
# PostgreSQL superuser username
POSTGRES_USERNAME=postgres
# PostgreSQL superuser password
POSTGRES_PASSWORD=evoai_dev_password
# Database name shared by all services
POSTGRES_DATABASE=evo_community

# =============================================================================
# REDIS
# =============================================================================
# Base URL (without DB number). Services override the DB in docker-compose:
#   Auth service → DB 1, CRM service → DB 0, Processor → DB 0

# Redis connection URL used by Rails services
REDIS_URL=redis://:evoai_redis_pass@redis:6379
# Redis password for authentication
REDIS_PASSWORD=evoai_redis_pass

# =============================================================================
# SHARED SECRETS
# =============================================================================
# These MUST be identical across all services that use them.
# Pre-generated for development — CHANGE in production!

# Secret key for Rails cookie signing and encryption (used by: auth, crm, core-service)
SECRET_KEY_BASE=e7XMfjicFewxGC9lFPsoHikx9IkyR0xs16rcB9nkQOhH8pDISBN0m3SqVoSelr
# JWT signing key — must match SECRET_KEY_BASE (used by: auth, crm, core-service)
JWT_SECRET_KEY=e7XMfjicFewxGC9lFPsoHikx9IkyR0xs16rcB9nkQOhH8pDISBN0m3SqVoSelr

# Fernet encryption key for API key storage (used by: core-service, processor)
ENCRYPTION_KEY=XoQPOBw2FrzjQS11utERG9qO2MsAnXFxlhIns_uUxRk=

# Token for service-to-service authentication (used by: auth, crm, processor)
EVOAI_CRM_API_TOKEN=6e10e689-58ce-4416-bf0d-f5818bf2dcf8

# =============================================================================
# AUTH SERVICE (evo-auth-service-community) — Port 3001
# =============================================================================

# Rails environment mode (development, production, test)
RAILS_ENV=development
# Maximum number of Rails threads per worker
RAILS_MAX_THREADS=5
# Frontend URL for CORS and redirect links
FRONTEND_URL=http://localhost:5173

# Doorkeeper JWT secret key for OAuth2 token signing
DOORKEEPER_JWT_SECRET_KEY=e7XMfjicFewxGC9lFPsoHikx9IkyR0xs16rcB9nkQOhH8pDISBN0m3SqVoSelr
# JWT signing algorithm for Doorkeeper
DOORKEEPER_JWT_ALGORITHM=hs256
# JWT issuer claim value
DOORKEEPER_JWT_ISS=evo-auth-service
# JWT audience claim (empty array = accept all)
DOORKEEPER_JWT_AUD=[]

# MFA issuer name shown in authenticator apps
MFA_ISSUER=EvoAI

# Default email sender address for outgoing emails
MAILER_SENDER_EMAIL=noreply@evoai-community.local

# SMTP server hostname (uses Mailhog in development — no real emails sent)
SMTP_ADDRESS=mailhog
# SMTP server port
SMTP_PORT=1025
# SMTP HELO domain
SMTP_DOMAIN=evoai-community.local
# SMTP authentication method (plain, login, cram_md5)
SMTP_AUTHENTICATION=plain
# Enable STARTTLS for SMTP connections
SMTP_ENABLE_STARTTLS_AUTO=false
# SMTP username (empty for Mailhog)
SMTP_USERNAME=
# SMTP password (empty for Mailhog)
SMTP_PASSWORD=

# Active Storage backend (local, amazon, s3_compatible)
ACTIVE_STORAGE_SERVICE=local

# Number of concurrent Sidekiq workers
SIDEKIQ_CONCURRENCY=10

# =============================================================================
# CRM SERVICE (evo-ai-crm-community) — Port 3000
# =============================================================================

# Public-facing CRM API base URL
BACKEND_URL=http://localhost:3000
# Core service internal URL (Docker hostname)
EVO_AI_CORE_SERVICE_URL=http://evo-core:5555
# Auth service internal URL (Docker hostname)
EVO_AUTH_SERVICE_URL=http://evo-auth:3001

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# Disable anonymous usage telemetry
DISABLE_TELEMETRY=true

# Send Rails logs to stdout (for Docker log collection)
RAILS_LOG_TO_STDOUT=true
# Log verbosity level (debug, info, warn, error)
LOG_LEVEL=info
# Maximum log file size in MB
LOG_SIZE=500

# Allow public account registration
ENABLE_ACCOUNT_SIGNUP=true

# Enable push notification relay server
ENABLE_PUSH_RELAY_SERVER=true

# Enable inbox event tracking
ENABLE_INBOX_EVENTS=true

# Facebook webhook verification token
FB_VERIFY_TOKEN=evolution
# Facebook Graph API version
FACEBOOK_API_VERSION=v23.0

# =============================================================================
# CORE SERVICE (evo-ai-core-service-community) — Port 5555
# =============================================================================

# Database hostname (Docker service name)
DB_HOST=postgres
# Database port
DB_PORT=5432
# Database username
DB_USER=postgres
# Database password
DB_PASSWORD=evoai_dev_password
# Database name
DB_NAME=evo_community
# SSL mode for database connections (disable, require, verify-full)
DB_SSLMODE=disable

# Maximum idle database connections in the pool
DB_MAX_IDLE_CONNS=10
# Maximum open database connections in the pool
DB_MAX_OPEN_CONNS=100
# Maximum lifetime of a database connection
DB_CONN_MAX_LIFETIME=1h
# Maximum idle time before a connection is closed
DB_CONN_MAX_IDLE_TIME=30m

# JWT signing algorithm — must match auth service
JWT_ALGORITHM=HS256

# CRM service internal URL for Evolution integration
EVOLUTION_BASE_URL=http://evo-crm:3000

# Auth service internal URL
EVO_AUTH_BASE_URL=http://evo-auth:3001

# AI Processor service internal URL
AI_PROCESSOR_URL=http://evo-processor:8000
# AI Processor API version
AI_PROCESSOR_VERSION=v1

# =============================================================================
# PROCESSOR SERVICE (evo-ai-processor-community) — Port 8000
# =============================================================================

# API display title
API_TITLE=Agent Processor Community
# API display description
API_DESCRIPTION=Agent Processor Community for Evo AI
# API semantic version
API_VERSION=1.0.0
# Public-facing API URL
API_URL=http://localhost:8000

# Organization display name
ORGANIZATION_NAME=Evo AI
# Organization website URL
ORGANIZATION_URL=https://evoai.evoapicloud.com

# PostgreSQL connection string (Processor uses URI format)
POSTGRES_CONNECTION_STRING=postgresql://postgres:evoai_dev_password@postgres:5432/evo_community

# Redis hostname (Docker service name)
REDIS_HOST=redis
# Redis port
REDIS_PORT=6379
# Redis database number for processor
REDIS_DB=0
# Enable Redis SSL/TLS
REDIS_SSL=false
# Key prefix for Redis entries
REDIS_KEY_PREFIX=a2a:
# Default TTL in seconds for Redis cached entries
REDIS_TTL=3600

# Enable tool definition caching
TOOLS_CACHE_ENABLED=true
# TTL in seconds for cached tool definitions
TOOLS_CACHE_TTL=3600

# CRM service internal URL (for CRM API tools)
EVO_AI_CRM_URL=http://evo-crm:3000

# Server bind address (0.0.0.0 to accept external connections)
HOST=0.0.0.0
# Server listen port
PORT=8000
# Enable debug mode (verbose logging)
DEBUG=false

# Core service internal URL for memory/knowledge APIs
CORE_SERVICE_URL=http://evo-core:5555/api/v1

# Public-facing application URL
APP_URL=http://localhost:8000

# =============================================================================
# FRONTEND (evo-ai-frontend-community) — Port 5173
# =============================================================================
# These are BUILD-TIME variables (baked into the frontend at build).
# They use localhost because the browser accesses them directly.

# Frontend environment mode (development, production)
VITE_APP_ENV=development
# CRM API URL as seen by the browser
VITE_API_URL=http://localhost:3000
# Auth API URL as seen by the browser
VITE_AUTH_API_URL=http://localhost:3001
# Core service API URL as seen by the browser
VITE_EVOAI_API_URL=http://localhost:5555
# Agent processor URL as seen by the browser
VITE_AGENT_PROCESSOR_URL=http://localhost:8000
# WebSocket URL for ActionCable real-time features
VITE_WS_URL=ws://localhost:3000/cable
# Optional: TinyMCE rich text editor API key
VITE_TINYMCE_API_KEY=no-api-key

# =============================================================================
# OPTIONAL — Social Channels (uncomment and configure as needed)
# =============================================================================

# Optional: WhatsApp Cloud API application ID
# WP_APP_ID=
# Optional: WhatsApp webhook verification token
# WP_VERIFY_TOKEN=evolution
# Optional: WhatsApp application secret
# WP_APP_SECRET=
# Optional: WhatsApp business configuration ID
# WP_WHATSAPP_CONFIG_ID=
# Optional: WhatsApp Graph API version
# WP_API_VERSION=v23.0

# Optional: Facebook Messenger application secret
# FB_APP_SECRET=
# Optional: Facebook Messenger application ID
# FB_APP_ID=

# Optional: Twitter/X application ID
# TWITTER_APP_ID=
# Optional: Twitter/X OAuth consumer key
# TWITTER_CONSUMER_KEY=
# Optional: Twitter/X OAuth consumer secret
# TWITTER_CONSUMER_SECRET=
# Optional: Twitter/X API environment name
# TWITTER_ENVIRONMENT=

# Optional: Slack OAuth client ID
# SLACK_CLIENT_ID=
# Optional: Slack OAuth client secret
# SLACK_CLIENT_SECRET=

# Optional: Google OAuth client ID for Gmail integration
# GOOGLE_OAUTH_CLIENT_ID=
# Optional: Google OAuth client secret
# GOOGLE_OAUTH_CLIENT_SECRET=
# Optional: Google OAuth callback URL
# GOOGLE_OAUTH_CALLBACK_URL=

# =============================================================================
# OPTIONAL — Cloud Storage (default: local filesystem)
# =============================================================================

# Optional: S3-compatible bucket name
# STORAGE_BUCKET_NAME=
# Optional: S3-compatible access key ID
# STORAGE_ACCESS_KEY_ID=
# Optional: S3-compatible secret access key
# STORAGE_SECRET_ACCESS_KEY=
# Optional: S3-compatible region
# STORAGE_REGION=
# Optional: S3-compatible endpoint URL
# STORAGE_ENDPOINT=

# =============================================================================
# OPTIONAL — APM & Monitoring
# =============================================================================

# Optional: Sentry DSN for error tracking
# SENTRY_DSN=

# Optional: Datadog trace agent URL
# DD_TRACE_AGENT_URL=

# Optional: NewRelic license key
# NEW_RELIC_LICENSE_KEY=

# Optional: OpenAI API key for AI-powered features
# OPENAI_API_KEY=
